# Frontend .env.example
# Copy to .env or .env.development and adjust as needed

# Backend API base URL
# Leave empty for local dev (uses vite proxy to http://localhost:8080)
# Set to http://localhost:8080 for Docker environment
VITE_BACKEND_URL=

# Middleware tokenizer URL
# Leave empty for local dev (uses vite proxy to http://localhost:3000)
# Set to http://middleware:3000 for Docker environment
VITE_MIDDLEWARE_URL=
