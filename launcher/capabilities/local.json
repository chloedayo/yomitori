{
    "identifier": "local",
    "description": "Local (splash) window capabilities. Allows sidecar spawn/kill and window control for the bundled loading page served from tauri://localhost.",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "core:window:allow-close",
        "core:window:allow-hide",
        "core:window:allow-show",
        "core:window:allow-set-focus",
        "core:path:default",
        "shell:allow-execute",
        "shell:allow-kill",
        {
            "identifier": "shell:allow-open",
            "allow": [{ "url": "http://localhost:3000/**" }]
        },
        "dialog:allow-open",
        "store:allow-get",
        "store:allow-set",
        "store:allow-save",
        "store:allow-load"
    ]
}
