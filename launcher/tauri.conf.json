{
    "productName": "yomitori",
    "version": "0.9.0",
    "identifier": "com.yomitori.app",
    "build": {
        "frontendDist": "../frontend/dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": ""
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "externalBin": [
            "binaries/yomitori-backend",
            "binaries/yomitori-middleware"
        ],
        "resources": {
            "resources/jre": "jre",
            "resources/yomitori.jar": "yomitori.jar",
            "resources/dist": "dist",
            "resources/deinflect-rules.json": "deinflect-rules.json",
            "resources/kuromoji-dict": "kuromoji-dict"
        },
        "linux": {
            "deb": { "depends": [] },
            "appimage": { "bundleMediaFramework": false }
        },
        "windows": {
            "nsis": {}
        },
        "macOS": {
            "minimumSystemVersion": "10.15"
        }
    },
    "app": {
        "windows": [
            {
                "title": "yomitori",
                "width": 1280,
                "height": 860,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "trayIcon": {
            "iconPath": "icons/32x32.png",
            "iconAsTemplate": true
        },
        "security": {
            "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: https://asset.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'"
        }
    }
}
