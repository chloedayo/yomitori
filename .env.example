# Yomitori Configuration
# Copy this to .env and customize for your setup

# Path to your book collection directory on the host
# Default: ./.books (create this directory and add your books there)
BOOKS_MOUNT=./books

# Internal path where books are mounted in the container
# (usually no need to change this)
BOOKS_PATH=/app/data/books

# Frontend port
FRONTEND_PORT=5173

# Backend port
BACKEND_PORT=8080
